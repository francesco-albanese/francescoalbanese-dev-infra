{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "target": "ES2021",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "types": ["aws-cloudfront-function"]
  },
  "include": ["src"]
}
